{
  "$schema": "https://design-tokens.org/schema.json",
  "iui": {
    "spacing": {
      "xs": { "$type": "dimension", "$value": "4px" },
      "sm": { "$type": "dimension", "$value": "8px" },
      "md": { "$type": "dimension", "$value": "16px" },
      "lg": { "$type": "dimension", "$value": "24px" },
      "xl": { "$type": "dimension", "$value": "32px" }
    },
    "light": {
      "color": {
        "primary": { "$type": "color", "$value": "#8b5cf6" },
        "secondary": { "$type": "color", "$value": "#393939" },
        "danger": { "$type": "color", "$value": "#da1e28" },
        "success": { "$type": "color", "$value": "#198038" },
        "warning": { "$type": "color", "$value": "#f1c21b" },
        "info": { "$type": "color", "$value": "#0f62fe" },
        "link": { "$type": "color", "$value": "#0f62fe" },
        "background": { "$type": "color", "$value": "#ffffff" },
        "text": { "$type": "color", "$value": "#111111" }
      }
    },
    "dark": {
      "color": {
        "primary": { "$type": "color", "$value": "#a78bfa" },
        "secondary": { "$type": "color", "$value": "#6f6f6f" },
        "danger": { "$type": "color", "$value": "#ff8389" },
        "success": { "$type": "color", "$value": "#42be65" },
        "warning": { "$type": "color", "$value": "#fdd13a" },
        "info": { "$type": "color", "$value": "#78a9ff" },
        "link": { "$type": "color", "$value": "#78a9ff" },
        "background": { "$type": "color", "$value": "#111111" },
        "text": { "$type": "color", "$value": "#ffffff" }
      }
    }
  }
}
